import axios from 'axios';
import { toast } from 'sonner';

// Base URL for the Spring Boot backend
const BASE_URL = 'ec2-13-60-247-126.eu-north-1.compute.amazonaws.com:10000';
const FULL_BASE_URL = `//${BASE_URL}`;

// Use Vite proxy during development so relative /api requests route through localhost and avoid CORS/network errors.
const getBaseURL = () => {
  return import.meta.env.DEV ? '' : FULL_BASE_URL;
};

// Parse the current server's URL to detect environment
const getCurrentServerUrl = () => {
  if (typeof window === 'undefined') return '';
  return window.location.origin;
};

// Helper to construct absolute URLs (e.g. for downloads/receipts)
export const getAbsoluteUrl = (path: string) => {
  return import.meta.env.DEV ? path : `${FULL_BASE_URL}${path}`;
};

// API Instance
export const api = axios.create({
  baseURL: getBaseURL(),
  headers: {
    'Content-Type': 'application/json',
  },
});

// Mock Mode Configuration
const MOCK_KEY = 'ts_mock_mode';
export const isMockMode = (): boolean => {
  const value = localStorage.getItem(MOCK_KEY);
  if (value === null) {
    // Default to live backend so the UI matches the deployed server unless demo mode is explicitly enabled
    return false;
  }
  return value === 'true';
};

export const setMockMode = (value: boolean) => {
  localStorage.setItem(MOCK_KEY, String(value));
  window.dispatchEvent(new Event('mock_mode_changed'));
};

// Request Interceptor: Attach JWT Token
api.interceptors.request.use(
  (config) => {
    const token = localStorage.getItem('ts_token');
    if (token && config.headers) {
      config.headers.Authorization = `Bearer ${token}`;
    }
    return config;
  },
  (error) => Promise.reject(error)
);

// Response Interceptor: Handle Authentication Errors & Unpack Response Wrappers
api.interceptors.response.use(
  (response) => {
    // Check if the response matches Spring Boot custom ApiResponse layout and unpack the inner data
    if (response.data && typeof response.data === 'object') {
      const resObj = response.data as any;
      if (resObj.success !== undefined && resObj.data !== undefined) {
        return {
          ...response,
          data: resObj.data,
        };
      }
    }
    return response;
  },
  (error) => {
    if (error.response && error.response.status === 401) {
      localStorage.removeItem('ts_token');
      localStorage.removeItem('ts_user');
      // If we are not on the login page, redirect and toast
      if (!window.location.pathname.includes('/login')) {
        toast.error('Session expired. Please log in again.');
        window.location.href = '/login';
      }
    }
    return Promise.reject(error);
  }
);

// ==========================================
// TYPES & INTERFACES
// ==========================================

export type UserRole = 'SUPER_ADMIN' | 'TREASURER' | 'USER';

export interface User {
  id: string; // UUID
  username: string;
  email: string;
  role: UserRole;
  fullName: string;
  isFirstLogin?: boolean;
  isActive?: boolean;
  createdAt?: string;
  updatedAt?: string;
}

export interface AuthResponse {
  success: boolean;
  message: string;
  data: string; // JWT token
}

export interface Event {
  id: string; // UUID
  name: string;
  description?: string;
  startDate: string; // ISO date
  endDate?: string; // ISO date
  treasurerId?: string;
  temporaryTreasurerId?: string;
  totalBalance: number;
  totalIncome: number;
  totalExpense: number;
  createdAt?: string;
  updatedAt?: string;
}

export interface Transaction {
  id: string; // UUID
  title: string;
  amount: number;
  type: 'INCOME' | 'EXPENSE';
  category: string;
  description?: string;
  fileUrl?: string;
  publicId?: string;
  originalFileName?: string;
  contentType?: string;
  eventId?: string | null; // null = Main Fund
  uploadedBy?: string;
  createdAt?: string;
  updatedAt?: string;
}

export interface Contribution {
  id: string; // UUID
  userId: string;
  month: string; // YYYY-MM format
  amount: number;
  isPaid: boolean;
  eventId?: string | null; // null = Main Fund
  transactionId?: string; // set once paid
  createdAt?: string;
  updatedAt?: string;
}

export interface DashboardStats {
  mainFundBalance: number;
  totalIncome: number;
  totalExpense: number;
  totalEvents: number;
  totalUsers: number;
  monthlyTrend: Array<{ month: string; income: number; expense: number }>;
  expenseByCategory: Array<{ category: string; amount: number }>;
}

export interface EventSummary {
  event: Event;
  transactions: Transaction[];
  contributions: Contribution[];
}

export interface AuditLog {
  id: string;
  action: string;
  entityType: string;
  entityId?: string;
  performedBy?: string;
  details?: string;
  timestamp?: string;
}

export interface PagedResponse<T> {
  content: T[];
  pageable: any;
  totalElements: number;
  totalPages: number;
  size: number;
  number: number;
  first: boolean;
  last: boolean;
  numberOfElements: number;
  empty: boolean;
}

export interface Contribution {
  id: number;
  title: string;
  amount: number;
  dueDate: string;
  status: 'PAID' | 'PENDING';
  eventId: number | null;
  eventName?: string;
  user: User;
  paymentProofUrl?: string | null;
  payDate?: string | null;
}

export interface EventSummary {
  eventId: number;
  eventName: string;
  totalBudget: number;
  collectedAmount: number;
  spentAmount: number;
  remainingAmount: number;
  paidContributionsCount: number;
  pendingContributionsCount: number;
}

