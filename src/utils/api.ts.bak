// Helper: simulate api latency
const delay = (ms = 400) => new Promise((resolve) => setTimeout(resolve, ms));

// ==========================================
// API ENDPOINT IMPLEMENTATIONS
// ==========================================

export const apiService = {
  // ----------------------------------------
  // AUTH
  // ----------------------------------------
  auth: {
    login: async (payload: any) => {
      if (isMockMode()) {
        await delay();
        const user = mockUsers.find(
          (u) => u.username === payload.username || u.email === payload.username
        );
        // In mock mode, the password must match the username (e.g., admin/admin)
        if (!user || payload.password !== user.username) {
          throw new Error('Invalid username or password');
        }
        // Force password change on first login simulation
        const mustChangePassword = payload.username === 'student3';
        return {
          data: {
            token: 'mock-jwt-token-xyz',
            user: { ...user, mustChangePassword },
          },
        };
      }
      return api.post('/api/auth/login', payload);
    },

    changePassword: async (payload: any) => {
      if (isMockMode()) {
        await delay();
        return { data: { message: 'Password changed successfully' } };
      }
      return api.post('/api/auth/change-password', payload);
    },

    forgotPasswordRequestOtp: async (email: string) => {
      if (isMockMode()) {
        await delay();
        toast.info('Mock OTP: 123456');
        return { data: { message: 'OTP sent successfully' } };
      }
      return api.post('/api/auth/forgot-password/request-otp', { email });
    },

    forgotPasswordReset: async (payload: any) => {
      if (isMockMode()) {
        await delay();
        return { data: { message: 'Password reset successfully' } };
      }
      return api.post('/api/auth/forgot-password/reset', payload);
    },
  },

  // ----------------------------------------
  // USERS (SUPER_ADMIN only)
  // ----------------------------------------
  users: {
    getAll: async () => {
      if (isMockMode()) {
        await delay();
        return { data: mockUsers };
      }
      return api.get('/api/admin/users');
    },

    create: async (userPayload: any) => {
      if (isMockMode()) {
        await delay();
        const newUser: User = {
          id: mockUsers.length + 1,
          username: userPayload.username,
          email: userPayload.email,
          fullName: userPayload.fullName,
          role: userPayload.role,
        };
        mockUsers.push(newUser);
        return { data: newUser };
      }
      return api.post('/api/admin/users', userPayload);
    },

    delete: async (id: number) => {
      if (isMockMode()) {
        await delay();
        const idx = mockUsers.findIndex((u) => u.id === id);
        if (idx > -1) mockUsers.splice(idx, 1);
        return { data: { message: 'User deleted successfully' } };
      }
      return api.delete(`/api/admin/users/${id}`);
    },

    resetPassword: async (id: number) => {
      if (isMockMode()) {
        await delay();
        return { data: { message: 'Password reset successful. Temporary password is "TempPass123!".' } };
      }
      return api.post(`/api/admin/users/${id}/reset-password`);
    },
  },

  // ----------------------------------------
  // DASHBOARD
  // ----------------------------------------
  dashboard: {
    getStats: async () => {
      if (isMockMode()) {
        await delay();
        // Compute balances
        const totalMainFundBalance = mockTransactions
          .filter((t) => t.eventId === null)
          .reduce((sum, t) => sum + (t.type === 'INCOME' ? t.amount : -t.amount), 5000); // 5000 starting main balance

        const totalEventFundsBalance = mockEvents.reduce((sum, e) => sum + e.balance, 0);
        
        const totalContributionsCollected = mockContributions
          .filter((c) => c.status === 'PAID')
          .reduce((sum, c) => sum + c.amount, 0);

        const pendingContributionsCount = mockContributions.filter(
          (c) => c.status === 'PENDING'
        ).length;

        const totalContributionsCount = mockContributions.length;
        const collectionRate = totalContributionsCount > 0 
          ? Math.round((mockContributions.filter(c => c.status === 'PAID').length / totalContributionsCount) * 100)
          : 0;

        const monthlyOverview = [
          { month: 'Jan', income: 1200, expense: 400 },
          { month: 'Feb', income: 1500, expense: 600 },
          { month: 'Mar', income: 2200, expense: 900 },
          { month: 'Apr', income: 1800, expense: 1200 },
          { month: 'May', income: 3000, expense: 1500 },
          { month: 'Jun', income: totalContributionsCollected, expense: 800 },
        ];

        return {
          data: {
            totalMainFundBalance,
            totalEventFundsBalance,
            totalContributionsCollected,
            pendingContributionsCount,
            collectionRate,
            monthlyOverview,
            recentTransactions: mockTransactions.slice(0, 5),
            upcomingContributions: mockContributions.filter(c => c.status === 'PENDING').slice(0, 3)
          } as DashboardStats,
        };
      }
      return api.get('/api/dashboard');
    },
  },

  // ----------------------------------------
  // EVENTS
  // ----------------------------------------
  events: {
    getAll: async () => {
      if (isMockMode()) {
        await delay();
        return { data: mockEvents };
      }
      return api.get('/api/treasurer/events');
    },

    create: async (eventPayload: any) => {
      if (isMockMode()) {
        await delay();
        const newEvent: Event = {
          id: mockEvents.length + 101,
          name: eventPayload.name,
          description: eventPayload.description,
          budget: Number(eventPayload.budget),
          balance: 0,
          status: 'ACTIVE',
          temporaryTreasurer: null,
          createdAt: new Date().toISOString().split('T')[0],
        };
        mockEvents.push(newEvent);
        return { data: newEvent };
      }
      return api.post('/api/treasurer/events', eventPayload);
    },

    delete: async (eventId: number) => {
      if (isMockMode()) {
        await delay();
        mockEvents = mockEvents.filter((e) => e.id !== eventId);
        return { data: { message: 'Event deleted successfully' } };
      }
      return api.delete(`/api/treasurer/events/${eventId}`);
    },

    assignTemporaryTreasurer: async (eventId: number, username: string | null) => {
      if (isMockMode()) {
        await delay();
        const targetEvent = mockEvents.find((e) => e.id === eventId);
        if (targetEvent) {
          const user = mockUsers.find((u) => u.username === username) || null;
          targetEvent.temporaryTreasurer = user;
        }
        return { data: targetEvent };
      }
      const param = username ? `?username=${encodeURIComponent(username)}` : '';
      return api.put(`/api/treasurer/events/${eventId}/temporary-treasurer${param}`);
    },

    getSummary: async (eventId: number) => {
      if (isMockMode()) {
        await delay();
        const event = mockEvents.find((e) => e.id === eventId);
        const relatedConts = mockContributions.filter((c) => c.eventId === eventId);
        const relatedTx = mockTransactions.filter((t) => t.eventId === eventId);

        const collected = relatedConts
          .filter((c) => c.status === 'PAID')
          .reduce((sum, c) => sum + c.amount, 0);

        const spent = relatedTx
          .filter((t) => t.type === 'EXPENSE')
          .reduce((sum, t) => sum + t.amount, 0);

        return {
          data: {
            eventId,
            eventName: event ? event.name : 'Unknown Event',
            totalBudget: event ? event.budget : 0,
            collectedAmount: collected,
            spentAmount: spent,
            remainingAmount: collected - spent,
            paidContributionsCount: relatedConts.filter((c) => c.status === 'PAID').length,
            pendingContributionsCount: relatedConts.filter((c) => c.status === 'PENDING').length,
          } as EventSummary,
        };
      }
      return api.get(`/api/treasurer/events/${eventId}/summary`);
    },

    getReportPdfUrl: (eventId: number) => {
      // Returns backend report download URL, but in mock mode we will download a sample PDF structure
      return getAbsoluteUrl(`/api/treasurer/events/${eventId}/report`);
    },

    getContributionReportPdfUrl: (eventId: number) => {
      return getAbsoluteUrl(`/api/treasurer/events/${eventId}/contribution-report`);
    },

    downloadReport: async (eventId: number, reportType: 'summary' | 'contribution') => {
      if (isMockMode()) {
        await delay(1000);
        // Simulate PDF download by generating a dummy plain text file representing a report
        const reportText = `UNIVERSITY TREASURY MANAGEMENT SYSTEM\n===============================\nEVENT REPORT: ${reportType.toUpperCase()}\nEvent ID: ${eventId}\nGenerated At: ${new Date().toLocaleString()}\nStatus: Verified\nTotal Budget: $8,500\nTotal Collected: $6,200\nTotal Spent: $4,350\nBalance: $1,850`;
        const blob = new Blob([reportText], { type: 'application/pdf' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `event_${eventId}_${reportType}_report.pdf`;
        a.click();
        window.URL.revokeObjectURL(url);
        return;
      }
      const endpoint = reportType === 'summary' 
        ? `/api/treasurer/events/${eventId}/report` 
        : `/api/treasurer/events/${eventId}/contribution-report`;
      
      const response = await api.get(endpoint, { responseType: 'blob' });
      const blob = new Blob([response.data], { type: 'application/pdf' });
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `event_${eventId}_report.pdf`;
      a.click();
      window.URL.revokeObjectURL(url);
    }
  },

  // ----------------------------------------
  // CONTRIBUTIONS
  // ----------------------------------------
  contributions: {
    getContributionsByEventForUser: async (eventId: number) => {
      if (isMockMode()) {
        await delay();
        return { data: mockContributions.filter((c) => c.eventId === eventId) };
      }
      return api.get(`/api/user/events/${eventId}/contributions`);
    },

    create: async (payload: any) => {
      if (isMockMode()) {
        await delay();
        const user = mockUsers.find((u) => u.id === Number(payload.userId)) || mockUsers[2];
        const event = mockEvents.find((e) => e.id === Number(payload.eventId));
        const newContribution: Contribution = {
          id: mockContributions.length + 201,
          title: payload.title,
          amount: Number(payload.amount),
          dueDate: payload.dueDate,
          status: 'PENDING',
          eventId: payload.eventId ? Number(payload.eventId) : null,
          eventName: event ? event.name : undefined,
          user,
          paymentProofUrl: null,
        };
        mockContributions.push(newContribution);
        return { data: newContribution };
      }
      return api.post('/api/treasurer/contributions', payload);
    },

    getById: async (id: number) => {
      if (isMockMode()) {
        await delay();
        return { data: mockContributions.find((c) => c.id === id) };
      }
      return api.get(`/api/treasurer/contributions/${id}`);
    },

    getUserContributions: async () => {
      if (isMockMode()) {
        await delay();
        // Return contributions for current logged in user (student1)
        return { data: mockContributions.filter((c) => c.user.username === 'student1') };
      }
      return api.get('/api/user/contributions');
    },

    getEventContributions: async (eventId: number) => {
      if (isMockMode()) {
        await delay();
        return { data: mockContributions.filter((c) => c.eventId === eventId) };
      }
      return api.get(`/api/treasurer/events/${eventId}/contributions`);
    },

    payContribution: async (id: number, file: File | string) => {
      if (isMockMode()) {
        await delay(800);
        const cont = mockContributions.find((c) => c.id === id);
        if (cont) {
          cont.status = 'PAID';
          cont.paymentProofUrl = typeof file === 'string' ? file : 'https://res.cloudinary.com/demo/image/upload/v1312461204/sample.jpg';
          cont.payDate = new Date().toISOString().split('T')[0];
        }
        return { data: cont };
      }
      
      // Real file upload usually requires FormData
      const formData = new FormData();
      formData.append('proof', file);
      return api.put(`/api/treasurer/contributions/${id}/pay`, formData, {
        headers: { 'Content-Type': 'multipart/form-data' },
      });
    },

    update: async (id: number, payload: any) => {
      if (isMockMode()) {
        await delay();
        const cont = mockContributions.find((c) => c.id === id);
        if (cont) {
          if (payload.amount !== undefined) cont.amount = Number(payload.amount);
          if (payload.title !== undefined) cont.title = payload.title;
          if (payload.dueDate !== undefined) cont.dueDate = payload.dueDate;
          if (payload.status !== undefined) cont.status = payload.status;
        }
        return { data: cont };
      }
      return api.put(`/api/treasurer/contributions/${id}`, payload);
    },

    delete: async (id: number) => {
      if (isMockMode()) {
        await delay();
        mockContributions = mockContributions.filter((c) => c.id !== id);
        return { data: { message: 'Contribution deleted successfully' } };
      }
      return api.delete(`/api/treasurer/contributions/${id}`);
    },

    sendReminders: async (eventId: number) => {
      if (isMockMode()) {
        await delay(1000);
        return { data: { message: 'Payment reminders sent successfully to all pending members.' } };
      }
      return api.post('/api/treasurer/reminders/send', { eventId });
    },

    getDefaultAmount: async () => {
      if (isMockMode()) {
        await delay();
        const amt = localStorage.getItem('ts_default_contribution_amount') || '25';
        return { data: Number(amt) };
      }
      return api.get('/api/treasurer/contributions/default-amount');
    },

    updateDefaultAmount: async (amount: number) => {
      if (isMockMode()) {
        await delay();
        localStorage.setItem('ts_default_contribution_amount', String(amount));
        return { data: amount };
      }
      return api.put(`/api/treasurer/contributions/default-amount?amount=${amount}`);
    },

    sendBroadcastEmail: async (subject: string, body: string, isTest = false, eventId?: number) => {
      if (isMockMode()) {
        await delay(1000);
        return { data: { message: isTest ? 'Test email sent successfully!' : 'Broadcast email dispatched to all members!' } };
      }
      return api.post('/api/treasurer/emails/broadcast', { subject, body, isTest, eventId });
    },
  },

  // ----------------------------------------
  // TRANSACTIONS
  // ----------------------------------------
  transactions: {
    create: async (payload: any) => {
      if (isMockMode()) {
        await delay(800);
        const event = mockEvents.find((e) => e.id === Number(payload.eventId));
        
        let proofUrl = null;
        if (payload.proof) {
          proofUrl = 'https://res.cloudinary.com/demo/image/upload/v1312461204/sample.jpg';
        }

        const newTx: Transaction = {
          id: mockTransactions.length + 301,
          amount: Number(payload.amount),
          type: payload.type,
          category: payload.category,
          description: payload.description,
          date: payload.date || new Date().toISOString().split('T')[0],
          proofUrl,
          eventId: payload.eventId ? Number(payload.eventId) : null,
          eventName: event ? event.name : undefined,
          recordedBy: mockUsers[1],
        };

        mockTransactions.unshift(newTx);

        // Adjust Event Balance if necessary
        if (event) {
          if (payload.type === 'INCOME') {
            event.balance += Number(payload.amount);
          } else {
            event.balance -= Number(payload.amount);
          }
        }

        return { data: newTx };
      }

      // Backend expects file upload as Multipart FormData
      const formData = new FormData();
      formData.append('amount', payload.amount);
      formData.append('type', payload.type);
      formData.append('category', payload.category);
      formData.append('description', payload.description);
      if (payload.date) formData.append('date', payload.date);
      if (payload.eventId) formData.append('eventId', payload.eventId);
      if (payload.proof) formData.append('proof', payload.proof);

      return api.post('/api/treasurer/transactions', formData, {
        headers: { 'Content-Type': 'multipart/form-data' },
      });
    },

    getMainFund: async () => {
      if (isMockMode()) {
        await delay();
        return { data: mockTransactions.filter((t) => t.eventId === null) };
      }
      return api.get('/api/treasurer/transactions/main');
    },

    getEventTransactions: async (eventId: number) => {
      if (isMockMode()) {
        await delay();
        return { data: mockTransactions.filter((t) => t.eventId === eventId) };
      }
      return api.get(`/api/treasurer/transactions/event/${eventId}`);
    },

    getReceiptFileUrl: (transactionId: number) => {
      return getAbsoluteUrl(`/api/files/${transactionId}`);
    },

    viewReceipt: async (transactionId: number): Promise<string> => {
      if (isMockMode()) {
        await delay();
        // Return dummy preview receipt
        return 'https://res.cloudinary.com/demo/image/upload/v1312461204/sample.jpg';
      }
      // Fetch as blob to attach JWT authorization headers via Axios interceptor
      const response = await api.get(`/api/files/${transactionId}`, { responseType: 'blob' });
      return URL.createObjectURL(response.data);
    },

    delete: async (id: number) => {
      if (isMockMode()) {
        await delay();
        const tx = mockTransactions.find((t) => t.id === id);
        if (tx && tx.eventId) {
          const event = mockEvents.find((e) => e.id === tx.eventId);
          if (event) {
            if (tx.type === 'INCOME') event.balance -= tx.amount;
            else event.balance += tx.amount;
          }
        }
        mockTransactions = mockTransactions.filter((t) => t.id !== id);
        return { data: { message: 'Transaction deleted successfully' } };
      }
      return api.delete(`/api/treasurer/transactions/${id}`);
    },
  },

  // ----------------------------------------
  // REPORTS
  // ----------------------------------------
  reports: {
    getMainFundMonthly: async (monthYear: string) => {
      if (isMockMode()) {
        await delay();
        const monthTx = mockTransactions.filter(
          (t) => t.eventId === null && t.date.startsWith(monthYear)
        );
        const income = monthTx.filter(t => t.type === 'INCOME').reduce((sum, t) => sum + t.amount, 0);
        const expense = monthTx.filter(t => t.type === 'EXPENSE').reduce((sum, t) => sum + t.amount, 0);

        return {
          data: {
            monthYear,
            openingBalance: 5000,
            incomeAmount: income,
            expenseAmount: expense,
            closingBalance: 5000 + income - expense,
            transactions: monthTx,
          },
        };
      }
      return api.get(`/api/treasurer/reports/main-fund/monthly`, {
        params: { monthYear },
      });
    },

    getContributionsPeriod: async (startMonth: string, endMonth: string, userId?: number) => {
      if (isMockMode()) {
        await delay();
        // Return summary of contributions matching dates
        return {
          data: {
            startMonth,
            endMonth,
            totalContributionsAmount: mockContributions.reduce((sum, c) => sum + c.amount, 0),
            collectedAmount: mockContributions.filter(c => c.status === 'PAID').reduce((sum, c) => sum + c.amount, 0),
            pendingAmount: mockContributions.filter(c => c.status === 'PENDING').reduce((sum, c) => sum + c.amount, 0),
            contributions: userId !== undefined 
              ? mockContributions.filter(c => c.user.id === userId)
              : mockContributions,
          },
        };
      }
      const params: any = { startMonth, endMonth };
      if (userId !== undefined) params.userId = userId;
      return api.get(`/api/treasurer/reports/contributions/period`, {
        params,
      });
    },
  },

  // ----------------------------------------
  // CURRENT USER
  // ----------------------------------------
  user: {
    getMe: async () => {
      if (isMockMode()) {
        await delay();
        const storedUser = localStorage.getItem('ts_user');
        const userObj = storedUser ? JSON.parse(storedUser) : mockUsers[0];
        return { data: userObj };
      }
      return api.get('/api/user/me');
    },
  },
};
